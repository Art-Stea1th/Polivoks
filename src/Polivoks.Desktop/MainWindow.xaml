<Window x:Class="Polivoks.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:Polivoks.Resources.Localization;assembly=Polivoks.Resources"
        xmlns:ctrl="clr-namespace:Polivoks.Resources.Controls;assembly=Polivoks.Resources"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{Binding WindowTitle}"
        Width="1320"
        Height="780"
        MinWidth="1100"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#FF070708">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="31"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="7"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border BorderBrush="#FF1B1B1D" BorderThickness="1" Background="#FF070708">
        <DockPanel>
        <Border DockPanel.Dock="Top" Height="31" Background="#FF0F0F10" BorderBrush="#FF151516" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding WindowTitle}"
                           Foreground="#FFE4F3F4"
                           VerticalAlignment="Center"
                           Margin="8,0,0,1"
                           FontSize="11"
                           IsHitTestVisible="False"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Click="OnMinimizeClick"
                            Style="{StaticResource WindowChromeButton}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Image Width="10" Height="11" Margin="0,6,0,0" RenderOptions.EdgeMode="Aliased">
                            <Image.Source>
                                <DrawingImage Drawing="{StaticResource ChromeMinimizeIcon}"/>
                            </Image.Source>
                        </Image>
                    </Button>
                    <Button Click="OnMaximizeRestoreClick"
                            Style="{StaticResource WindowChromeButton}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Image Width="10" Height="11" Margin="0,1,0,0" RenderOptions.EdgeMode="Aliased">
                            <Image.Source>
                                <DrawingImage Drawing="{StaticResource ChromeResizeIcon}"/>
                            </Image.Source>
                        </Image>
                    </Button>
                    <Button Click="OnCloseClick"
                            Style="{StaticResource WindowChromeCloseButton}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Image Width="10" Height="11" Margin="0,1,0,0" RenderOptions.EdgeMode="Aliased">
                            <Image.Source>
                                <DrawingImage Drawing="{StaticResource ChromeCloseIcon}"/>
                            </Image.Source>
                        </Image>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        <Border DockPanel.Dock="Top" Height="24" Background="#FF070708" BorderBrush="#FF101012" BorderThickness="0,0,0,1">
        <Menu FontSize="11" Padding="2,0,0,0" Background="#FF070708">
            <MenuItem Header="{loc:Loc MenuSettings}" Command="{Binding OpenSettingsCommand}"/>
            <MenuItem Header="{loc:Loc MenuPresets}">
                <MenuItem Header="{loc:Loc PresetSave}" Command="{Binding SavePresetCommand}"/>
                <MenuItem Header="{loc:Loc PresetLoad}" Command="{Binding LoadPresetCommand}"/>
            </MenuItem>
            <MenuItem Header="{loc:Loc MenuRecord}">
                <MenuItem Header="{loc:Loc StartRecording}" Command="{Binding ToggleRecordingCommand}"/>
                <MenuItem Header="{loc:Loc ExportRecording}" Command="{Binding ExportRecordingCommand}"/>
            </MenuItem>
            <MenuItem Header="{loc:Loc MenuMidi}">
                <MenuItem Header="{loc:Loc LoadMidi}" Command="{Binding LoadMidiCommand}"/>
                <MenuItem Header="{loc:Loc PlayMidi}" Command="{Binding PlayMidiCommand}"/>
                <MenuItem Header="{loc:Loc StopMidi}" Command="{Binding StopMidiCommand}"/>
                <MenuItem Header="{loc:Loc ConvertMidiToAudio}" Command="{Binding ConvertMidiToAudioCommand}"/>
            </MenuItem>
        </Menu>
        </Border>

        <StatusBar DockPanel.Dock="Bottom" Height="28">
            <StatusBarItem>
                <TextBlock Text="LOG" Foreground="#FF4FD7D6" FontWeight="SemiBold" Margin="0,0,8,0"/>
            </StatusBarItem>
            <StatusBarItem Width="420">
                <TextBlock Text="{Binding StatusMessage}" TextTrimming="CharacterEllipsis"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding AudioInfo}" Foreground="#FFA8F4F2"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding PatchInfo}" Foreground="#FF8EC8CA"/>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Viewbox Stretch="Uniform" Margin="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                     RenderOptions.BitmapScalingMode="Fant">
                <ctrl:SynthPanelView x:Name="Panel" Patch="{Binding Patch}" Width="1280" Height="680"/>
            </Viewbox>
        </Grid>
        </DockPanel>
    </Border>
</Window>
