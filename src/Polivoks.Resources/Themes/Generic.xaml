<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ctrl="clr-namespace:Polivoks.Resources.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Polivoks.Resources;component/Themes/PolivoksTheme.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="{x:Type ctrl:ModulePanel}">
        <Setter Property="Width" Value="156"/>
        <Setter Property="MinHeight" Value="460"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ctrl:ModulePanel}">
                    <Border Background="#FF1A2A2C"
                            BorderBrush="#FF2E7E83"
                            BorderThickness="1.5"
                            CornerRadius="0"
                            Padding="8,10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="#FF0D171C"
                                    BorderBrush="#FF2E7E83"
                                    BorderThickness="0,0,0,1"
                                    Margin="-8,-10,-8,10"
                                    Padding="6,5">
                                <StackPanel>
                                    <TextBlock Text="{TemplateBinding Title}"
                                               Foreground="#FFE4F3F4"
                                               FontWeight="Bold"
                                               FontSize="11"
                                               TextAlignment="Center"/>
                                    <TextBlock Text="{TemplateBinding Subtitle}"
                                               Foreground="#FF4FD7D6"
                                               FontSize="9"
                                               TextAlignment="Center"
                                               Margin="0,1,0,0"/>
                                </StackPanel>
                            </Border>

                            <ContentPresenter Grid.Row="1" HorizontalAlignment="Center"/>

                            <Rectangle Width="7" Height="7" Fill="#FF070B10" Stroke="#FF2E7E83" StrokeThickness="0.8"
                                     HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-4,-4,0,0"/>
                            <Rectangle Width="7" Height="7" Fill="#FF070B10" Stroke="#FF2E7E83" StrokeThickness="0.8"
                                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-4,0"/>
                            <Rectangle Width="7" Height="7" Fill="#FF070B10" Stroke="#FF2E7E83" StrokeThickness="0.8"
                                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-4,0,0,-4"/>
                            <Rectangle Width="7" Height="7" Fill="#FF070B10" Stroke="#FF2E7E83" StrokeThickness="0.8"
                                     HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-4,-4"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ctrl:SynthToggle}">
        <Setter Property="Width" Value="52"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="Margin" Value="4,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ctrl:SynthToggle}">
                    <Grid>
                        <Border Height="14"
                                VerticalAlignment="Top"
                                Margin="0,4,0,0"
                                Background="#FF05080B"
                                BorderBrush="#FF2E7E83"
                                BorderThickness="1"
                                CornerRadius="0"/>
                        <Border x:Name="Thumb"
                                Width="18"
                                Height="18"
                                VerticalAlignment="Top"
                                Background="#FF4FD7D6"
                                BorderBrush="#FFA8F4F2"
                                BorderThickness="1"
                                CornerRadius="0">
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="ThumbShift" X="0"/>
                            </Border.RenderTransform>
                        </Border>
                        <TextBlock Text="{TemplateBinding Label}"
                                   Foreground="#FF4FD7D6"
                                   FontSize="9"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Bottom"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbShift"
                                                         Storyboard.TargetProperty="X"
                                                         To="30"
                                                         Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ThumbShift"
                                                         Storyboard.TargetProperty="X"
                                                         To="0"
                                                         Duration="0:0:0.08"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
